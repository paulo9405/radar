# Django Settings
# Generate a new secret key for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Debug mode - MUST be False in production
DEBUG=False

# Allowed hosts - comma-separated list
# Example: yourapp.onrender.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF trusted origins - comma-separated list with https:// prefix
# Example: https://yourapp.onrender.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourapp.onrender.com

# Database
# Render will automatically provide this as an environment variable when you add PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/database

# Redis Cache (for persistent OAuth tokens)
# Render will provide this when you add Redis
# Local development: Leave empty to use in-memory cache
REDIS_URL=redis://host:port

# Mercado Livre API Configuration
# Get credentials from: https://developers.mercadolivre.com.br/
# IMPORTANT: Never commit these values to version control
MERCADO_LIVRE_CLIENT_ID=your-client-id-here
MERCADO_LIVRE_CLIENT_SECRET=your-client-secret-here
MERCADO_LIVRE_REDIRECT_URI=https://your-domain.com/market/mercadolivre/callback/
